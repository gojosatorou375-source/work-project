{
  "name": "sisu-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @sisu/web run dev",
    "dev:api": "npm --workspace @sisu/api run dev",
    "build:web": "npm --workspace @sisu/web run build",
    "start:web": "npm --workspace @sisu/web run start",
    "lint:web": "npm --workspace @sisu/web run lint"
  }
}
